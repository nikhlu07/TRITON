# ==========================================
# TRITON - Environment Variables Config
# ==========================================

# 1. Hedera Network Configuration (Testnet)
HEDERA_NETWORK=testnet
# The operator account ID that acts as the treasury and DID owner
HEDERA_ACCOUNT_ID="0.0.xxxxx"
HEDERA_PRIVATE_KEY="YOUR_DER_ENCODED_PRIVATE_KEY_HERE"

# 2. AWS KMS Configuration
# Ensure you are using a key like ECC_NIST_P256 or ED25519
AWS_REGION="eu-north-1"
AWS_KMS_KEY_ARN="arn:aws:kms:us-east-1:123456789012:key/xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# If running locally, you'll need these. If running on EC2/Lambda, IAM roles are preferred.
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_KEY"

# 3. DID Configurations (Populated automatically after running 'npm run register-dids')
DID_FACTORY="did:hedera:testnet:z6Mxxxxx..."
DID_SENSOR_PH="did:hedera:testnet:z6Mxxxxx..."
DID_SENSOR_TDS="did:hedera:testnet:z6Mxxxxx..."
DID_SENSOR_FLOW="did:hedera:testnet:z6Mxxxxx..."

# 4. HCS Topic
# The Hedera Consensus Service Topic ID where the sensor streams the signed hashes
HCS_TOPIC_ID="0.0.yyyyy"
